# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: anthropic, openai, ollama
LLM_PROVIDER=ollama

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-2024-08-06

# Ollama (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ── Meta API ──────────────────────────────────────────────────────────────────
META_API_VERSION=v21.0
# Get APP_ID and APP_SECRET from https://developers.facebook.com/apps -> Your App -> Settings -> Basic
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_access_token
META_AD_ACCOUNT_ID=act_123456789

# Token encryption key for Meta access tokens (AES-256-GCM).
# MUST be exactly 32 bytes, base64url-encoded. Separate from JWT_SECRET.
# Generate with: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
META_TOKEN_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_32_BYTE_KEY

# OAuth callback URL (must match Meta App settings -> Facebook Login -> Valid OAuth Redirect URIs)
META_OAUTH_REDIRECT_URI=http://localhost:8000/api/meta/oauth/callback

# OAuth scopes (comma-separated). Use "ads_read" for read-only, add "ads_management" for write ops.
META_OAUTH_SCOPES=ads_read

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///./meta_ops_agent.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/meta_ops_agent

# ── Vector Database ───────────────────────────────────────────────────────────
VECTOR_DB_PATH=./chroma_data

# ── JWT Authentication ────────────────────────────────────────────────────
# REQUIRED: Secret key for signing JWT tokens. Use a random 32+ char string.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_KEY
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PYTHONPATH=.

# ── Frontend (set in frontend/.env) ──────────────────────────────────────────
# VITE_API_URL=http://localhost:8000/api
